# ==============================================================================
# 🏠 Homelabbing Stacks Environment Configuration Template (.env.example)
#
# INSTRUCTIONS:
# 1. Copy this file to '.env' inside the 'stacks/' directory:
#    $ cp .env.example .env
# 2. Open '.env' in a text editor ($ nano .env) and fill in your actual values.
# 3. Docker Compose will automatically inject these variables when you run:
#    $ cd stacks/media-server && docker compose up -d
#
# IMPORTANT SECURITY NOTICE:
# Never commit your actual '.env' file containing real secrets to GitHub!
# Our .gitignore is pre-configured to block '.env' files from tracking.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. User & Group Permissions (PUID / PGID)
# ------------------------------------------------------------------------------
# Why? When Docker containers write files to your hard drive (/data/media),
# they must write them using YOUR Linux user ID (`PUID`) and group ID (`PGID`).
# If omitted, containers run as root (ID 0) and create locked files you cannot delete!
#
# How to find yours: Run `id` inside your terminal:
#   $ id
#   uid=1000(ubuntu) gid=1000(ubuntu) groups=1000(ubuntu),999(docker)
# ------------------------------------------------------------------------------
PUID=1000
PGID=1000

# ------------------------------------------------------------------------------
# 2. Timezone & Server Identification
# ------------------------------------------------------------------------------
# Set TZ to match your physical local timezone so container scheduled tasks,
# automated backup crons, and log timestamps match your watch.
# Example values: America/New_York, Europe/London, Asia/Tokyo, UTC
# ------------------------------------------------------------------------------
TZ=America/New_York

# Your home server's static Local Area Network (LAN) IP address.
# Used by diagnostic helper scripts and reverse proxy configurations.
SERVER_IP=192.168.1.100

# ------------------------------------------------------------------------------
# 3. Storage Root Paths
# ------------------------------------------------------------------------------
# DATA_ROOT: Where your physical media files and downloads live on your pooled drives.
# CONFIG_ROOT: Where containers save their persistent database and setting files.
# ------------------------------------------------------------------------------
DATA_ROOT=/data
CONFIG_ROOT=/opt/homelab/stacks

# ------------------------------------------------------------------------------
# 4. API Keys for Automation Stack (arr-stack)
# ------------------------------------------------------------------------------
# Once you launch Radarr, Sonarr, and Prowlarr, copy their API keys from their
# web settings (Settings -> General) into these variables so Recyclarr can connect.
# ------------------------------------------------------------------------------
RADARR_API_KEY=your_radarr_api_key_here
SONARR_API_KEY=your_sonarr_api_key_here
PROWLARR_API_KEY=your_prowlarr_api_key_here

# ------------------------------------------------------------------------------
# 5. Database Credentials (Nextcloud & Immich)
# ------------------------------------------------------------------------------
# Choose strong, unique passwords for internal database authentication.
# Since databases live inside isolated Docker networks (`internal: true`),
# these credentials only authenticate container-to-container communication.
# ------------------------------------------------------------------------------
DB_ROOT_PASSWORD=ChangeThisToASecureRootPassword123!
NEXTCLOUD_DB_PASSWORD=ChangeThisToASecureNextcloudPassword123!
IMMICH_DB_PASSWORD=ChangeThisToASecureImmichPassword123!

# ------------------------------------------------------------------------------
# 6. Networking & Remote Access Options (DuckDNS / Cloudflare / Tailscale)
# ------------------------------------------------------------------------------
# Only required if you launch stacks from stacks/networking/
# ------------------------------------------------------------------------------
DUCKDNS_SUBDOMAIN=your-duckdns-subdomain
DUCKDNS_TOKEN=your-duckdns-token-xxxxxxxx
CF_API_TOKEN=your-cloudflare-dns-edit-token-xxxxxxxx
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
