# ==============================================================================
# Homelab Quickstart Environment Variables Template
# Copy this file to .env and adjust variables as needed before launching!
# ==============================================================================

# User ID and Group ID permissions for containers (run `id` in terminal to find yours)
PUID=1000
PGID=1000
TZ=UTC

# Storage paths on the host system
MEDIA_DIR=/srv/media
DOWNLOADS_DIR=/srv/downloads
MUSIC_DIR=/srv/music
PHOTOS_DIR=/srv/photos
CLOUD_DIR=/srv/nextcloud

# Nextcloud MariaDB Database Credentials
DB_ROOT_PASSWORD=           # Nextcloud MariaDB root password
DB_PASSWORD=                # Nextcloud MariaDB user password

# Immich PostgreSQL Database Credentials
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=         # Immich PostgreSQL password
IMMICH_DB_NAME=immich
DB_HOSTNAME=immich-db       # Leave as-is
DB_PORT=5432                # Leave as-is
REDIS_HOSTNAME=immich-redis # Leave as-is

# Networking & Remote Access Options
DUCKDNS_SUBDOMAIN=          # Option A: your DuckDNS subdomain (e.g. myhomelab)
DUCKDNS_TOKEN=              # Option A: your DuckDNS token
CF_API_TOKEN=               # Option B/C: Cloudflare API token with Zone:DNS:Edit permissions
TAILSCALE_AUTH_KEY=         # Option D: Tailscale auth key (e.g. tskey-auth-xxxxx)
