---
interface Props {
  title: string;
  url: string;
  type?: 'wizard' | 'library' | 'login' | 'onboarding';
}

const { title, url, type = 'wizard' } = Astro.props;
---

<div class="ui-mockup my-8 not-prose shadow-2xl">
  <div class="terminal-titlebar justify-between">
    <div class="flex items-center gap-2">
      <span class="terminal-dot bg-red-500/90"></span>
      <span class="terminal-dot bg-yellow-500/90"></span>
      <span class="terminal-dot bg-green-500/90"></span>
      <span class="text-xs text-text-muted ml-2 font-medium truncate">{title}</span>
    </div>
    <span class="text-[10px] text-text-faint font-mono uppercase tracking-wider bg-bg px-2.5 py-0.5 rounded border border-border/80">
      Interactive Preview
    </span>
  </div>

  <div class="ui-mockup-urlbar">
    <span class="text-accent">🔒</span>
    <span class="text-text tracking-wide truncate">{url}</span>
  </div>

  <div class="ui-mockup-content">
    {type === 'wizard' && (
      <div class="max-w-md mx-auto py-8 text-center space-y-6 animate-fade-in">
        <div class="w-16 h-16 rounded-2xl bg-accent/20 border border-accent/40 mx-auto flex items-center justify-center text-3xl shadow-[0_0_30px_rgba(99,102,241,0.25)]">
          ✨
        </div>
        <div>
          <h4 class="text-xl font-bold text-text">Welcome to {title} Setup</h4>
          <p class="text-xs text-text-muted mt-1">Please select your preferred display language to continue.</p>
        </div>
        <div class="p-4 rounded-xl bg-bg-elevated border border-border text-left space-y-3 shadow-inner">
          <div class="flex justify-between text-xs text-text-muted">
            <span>Display Language</span>
            <span class="text-accent font-semibold">English (United States)</span>
          </div>
          <div class="w-full h-2 bg-bg rounded-full overflow-hidden">
            <div class="w-1/4 h-full bg-accent rounded-full animate-pulse"></div>
          </div>
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <span class="px-5 py-2.5 rounded-xl bg-accent text-white text-xs font-semibold shadow-md">Next Step →</span>
        </div>
      </div>
    )}

    {type === 'library' && (
      <div class="space-y-4 animate-fade-in">
        <div class="flex items-center justify-between border-b border-border/80 pb-3">
          <div class="flex gap-4 text-xs font-semibold text-text-muted">
            <span class="text-accent border-b-2 border-accent pb-3 -mb-3 font-bold">Movies</span>
            <span class="hover:text-text cursor-pointer transition-colors">TV Shows</span>
            <span class="hover:text-text cursor-pointer transition-colors">Requests (12)</span>
          </div>
          <span class="px-3 py-1 rounded-lg bg-accent/20 text-accent text-xs font-mono font-semibold">+ Add Request</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-2">
          {[1, 2, 3, 4].map((i) => (
            <div class="aspect-[2/3] rounded-xl bg-bg-elevated border border-border p-3 flex flex-col justify-end relative overflow-hidden group hover:border-accent/60 transition-all">
              <div class="absolute inset-0 bg-gradient-to-t from-bg-surface via-bg-surface/40 to-transparent opacity-90"></div>
              <span class="text-xs font-bold text-text relative z-10 truncate">Demo Media #{i}</span>
              <span class="text-[10px] text-accent relative z-10 font-mono font-semibold">1080p Web-DL</span>
            </div>
          ))}
        </div>
      </div>
    )}

    {type === 'login' && (
      <div class="max-w-sm mx-auto py-10 space-y-5 animate-fade-in">
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-amber-500/20 border border-amber-500/40 mx-auto flex items-center justify-center text-3xl mb-3 shadow-[0_0_25px_rgba(245,158,11,0.2)]">
            🎵
          </div>
          <h4 class="font-bold text-text text-lg">{title}</h4>
          <p class="text-xs text-text-faint mt-1">Enter admin credentials to access your lossless audio cloud</p>
        </div>
        <div class="space-y-3 p-5 rounded-2xl bg-bg-elevated border border-border shadow-inner">
          <div class="h-9 rounded-lg bg-bg border border-border/80 flex items-center px-3 text-xs text-text-faint font-mono">admin_user</div>
          <div class="h-9 rounded-lg bg-bg border border-border/80 flex items-center px-3 text-xs text-text-faint font-mono">••••••••••••</div>
          <div class="h-10 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-semibold text-xs flex items-center justify-center shadow-lg shadow-amber-500/25 transition-colors cursor-pointer">Sign In</div>
        </div>
      </div>
    )}

    {type === 'onboarding' && (
      <div class="max-w-md mx-auto py-8 space-y-6 animate-fade-in">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-2xl bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center text-3xl shrink-0 shadow-[0_0_25px_rgba(99,102,241,0.2)]">
            🖼️
          </div>
          <div>
            <h4 class="font-bold text-text text-base">Immich Machine Learning Setup</h4>
            <p class="text-xs text-text-muted mt-0.5">Hardware acceleration & local CLIP inference models</p>
          </div>
        </div>
        <div class="space-y-3">
          <div class="p-3.5 rounded-xl bg-bg-elevated border border-border flex items-center justify-between text-xs">
            <span class="text-text font-medium">Facial Recognition Model (CLIP)</span>
            <span class="px-2.5 py-0.5 rounded-full bg-success/20 text-success font-semibold">Ready</span>
          </div>
          <div class="p-3.5 rounded-xl bg-bg-elevated border border-border flex items-center justify-between text-xs">
            <span class="text-text font-medium">Storage Directory Structure</span>
            <code class="text-accent font-mono text-[11px]">YEAR/MONTH-DAY/FILE</code>
          </div>
        </div>
      </div>
    )}
  </div>
</div>
