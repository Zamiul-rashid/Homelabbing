---
interface Props {
  title: string;
  url: string;
  type?: 'wizard' | 'library' | 'login' | 'onboarding';
}

const { title, url, type = 'wizard' } = Astro.props;
---

<div class="ui-mockup my-8 not-prose">
  <div class="terminal-titlebar justify-between">
    <div class="flex items-center gap-2">
      <span class="terminal-dot bg-red-500"></span>
      <span class="terminal-dot bg-yellow-500"></span>
      <span class="terminal-dot bg-green-500"></span>
      <span class="text-xs text-text-muted ml-2 font-medium">{title}</span>
    </div>
    <span class="text-[10px] text-text-faint font-mono uppercase tracking-wider bg-bg px-2 py-0.5 rounded border border-border">
      CSS UI Mockup
    </span>
  </div>

  <div class="ui-mockup-urlbar">
    <span class="text-accent">🔒</span>
    <span class="text-text tracking-wide">{url}</span>
  </div>

  <div class="ui-mockup-content bg-bg/90">
    {type === 'wizard' && (
      <div class="max-w-md mx-auto py-8 text-center space-y-6 animate-fade-in">
        <div class="w-16 h-16 rounded-2xl bg-accent/20 border border-accent/40 mx-auto flex items-center justify-center text-3xl shadow-[0_0_30px_rgba(99,102,241,0.2)]">
          ✨
        </div>
        <div>
          <h4 class="text-xl font-bold text-text">Welcome to {title} Setup</h4>
          <p class="text-xs text-text-muted mt-1">Please select your preferred display language to continue.</p>
        </div>
        <div class="p-4 rounded-xl bg-bg-elevated border border-border text-left space-y-3">
          <div class="flex justify-between text-xs text-text-muted">
            <span>Language</span>
            <span class="text-accent font-semibold">English (United States)</span>
          </div>
          <div class="w-full h-2 bg-bg rounded-full overflow-hidden">
            <div class="w-1/4 h-full bg-accent rounded-full"></div>
          </div>
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <span class="px-4 py-2 rounded-lg bg-accent text-white text-xs font-semibold">Next →</span>
        </div>
      </div>
    )}

    {type === 'library' && (
      <div class="space-y-4 animate-fade-in">
        <div class="flex items-center justify-between border-b border-border pb-3">
          <div class="flex gap-4 text-xs font-semibold text-text-muted">
            <span class="text-accent border-b-2 border-accent pb-3 -mb-3">Movies</span>
            <span>TV Shows</span>
            <span>Requests (12)</span>
          </div>
          <span class="px-3 py-1 rounded bg-accent/20 text-accent text-xs font-mono">+ Add New</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-2">
          {[1, 2, 3, 4].map((i) => (
            <div class="aspect-[2/3] rounded-lg bg-bg-elevated border border-border p-3 flex flex-col justify-end relative overflow-hidden group">
              <div class="absolute inset-0 bg-gradient-to-t from-bg-surface via-transparent to-transparent opacity-80"></div>
              <span class="text-xs font-bold text-text relative z-10">Demo Movie Title #{i}</span>
              <span class="text-[10px] text-accent relative z-10 font-mono">1080p Web-DL</span>
            </div>
          ))}
        </div>
      </div>
    )}

    {type === 'login' && (
      <div class="max-w-sm mx-auto py-10 space-y-5 animate-fade-in">
        <div class="text-center">
          <div class="w-12 h-12 rounded-xl bg-amber-500/20 border border-amber-500/40 mx-auto flex items-center justify-center text-2xl mb-3">
            🎵
          </div>
          <h4 class="font-bold text-text">{title}</h4>
          <p class="text-xs text-text-faint">Enter admin credentials to start scanning</p>
        </div>
        <div class="space-y-3 p-5 rounded-xl bg-bg-elevated border border-border">
          <div class="h-8 rounded bg-bg border border-border/60 flex items-center px-3 text-xs text-text-faint">username</div>
          <div class="h-8 rounded bg-bg border border-border/60 flex items-center px-3 text-xs text-text-faint">••••••••••••</div>
          <div class="h-9 rounded bg-amber-500 text-white font-semibold text-xs flex items-center justify-center shadow-lg shadow-amber-500/20">Sign In</div>
        </div>
      </div>
    )}

    {type === 'onboarding' && (
      <div class="max-w-md mx-auto py-8 space-y-6 animate-fade-in">
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-2xl bg-indigo-500/20 border border-indigo-500/40 flex items-center justify-center text-3xl">
            🖼️
          </div>
          <div>
            <h4 class="font-bold text-text">Immich Machine Learning Setup</h4>
            <p class="text-xs text-text-muted">Hardware acceleration & smart search models</p>
          </div>
        </div>
        <div class="space-y-3">
          <div class="p-3 rounded-lg bg-bg-elevated border border-border flex items-center justify-between text-xs">
            <span class="text-text">Facial Recognition Model (CLIP)</span>
            <span class="px-2 py-0.5 rounded bg-success-muted text-success">Loaded</span>
          </div>
          <div class="p-3 rounded-lg bg-bg-elevated border border-border flex items-center justify-between text-xs">
            <span class="text-text">Storage Template Format</span>
            <code class="text-accent font-mono">YEAR/MONTH-DAY/FILE</code>
          </div>
        </div>
      </div>
    )}
  </div>
</div>
