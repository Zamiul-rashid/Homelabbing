---
import { services } from '../data/services';
---

<div class="glass overflow-hidden my-8 border border-border shadow-lg">
  <div class="p-4 bg-bg-elevated border-b border-border flex flex-wrap items-center justify-between gap-2">
    <h3 class="font-bold text-text flex items-center gap-2">
      <span>🩺</span>
      <span>Quick Health Check Port Reference</span>
    </h3>
    <code class="text-xs text-accent font-mono px-2 py-1 rounded bg-bg">helpers/check-health.sh</code>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm font-mono">
      <thead class="bg-bg/50 text-text-muted border-b border-border">
        <tr>
          <th class="py-3.5 px-4 font-semibold">Service</th>
          <th class="py-3.5 px-4 font-semibold">Default Port</th>
          <th class="py-3.5 px-4 font-semibold">Local URL</th>
          <th class="py-3.5 px-4 font-semibold">Folder Path</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border/50 text-text">
        {services.map((s) => (
          <tr class="hover:bg-bg-surface/60 transition-colors">
            <td class="py-3.5 px-4 font-semibold flex items-center gap-2.5">
              <span class="text-xl">{s.icon}</span>
              <span>{s.name}</span>
            </td>
            <td class="py-3.5 px-4 text-accent font-bold">{s.port}</td>
            <td class="py-3.5 px-4 text-text-muted">http://YOUR_SERVER_IP:{s.port}</td>
            <td class="py-3.5 px-4 text-xs text-text-faint">stacks/{s.folder}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
