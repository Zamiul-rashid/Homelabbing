---
const currentYear = new Date().getFullYear();
---

<footer class="bg-bg-surface border-t border-border mt-20 py-12">
  <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-accent flex items-center justify-center text-white font-bold text-sm">
        🏠
      </div>
      <div>
        <span class="font-bold text-text block">Homelabbing</span>
        <span class="text-xs text-text-faint">Open Source Self-Hosting & Modular Stacks Guide</span>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-6 text-sm text-text-muted">
      <a href="/Homelabbing/getting-started" class="hover:text-text transition-colors">Getting Started</a>
      <a href="/Homelabbing/concepts" class="hover:text-text transition-colors">Core Concepts</a>
      <a href="/Homelabbing/networking" class="hover:text-text transition-colors">Networking</a>
      <a href="https://github.com/Zamiul-rashid/Homelabbing" target="_blank" rel="noopener noreferrer" class="hover:text-text transition-colors">GitHub</a>
      <a href="https://trash-guides.info" target="_blank" rel="noopener noreferrer" class="hover:text-text transition-colors">TRaSH Guides</a>
    </div>

    <div class="text-xs text-text-faint text-center md:text-right font-mono">
      <p>© {currentYear} Zamiul Rashid. Open Source (MIT).</p>
      <p class="mt-1">Zero Secrets. Zero Telemetry. 100% Self-Hosted.</p>
    </div>
  </div>
</footer>
