---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceFilter from '../../components/ServiceFilter';
import HealthTable from '../../components/HealthTable.astro';
import { services } from '../../data/services';
---

<PageLayout
  title="Modular Homelab Services"
  description="Explore our beginner-friendly Docker Compose suites. Use the interactive tabs below to filter by difficulty or service category."
>
  <!-- Interactive Filter Island -->
  <div class="not-prose mb-14">
    <ServiceFilter client:load services={services} />
  </div>

  <!-- Why Modular Section -->
  <div class="space-y-6 pt-10 border-t border-border">
    <h2>Why Modular Architecture?</h2>
    <p>
      Traditional homelab repositories dump 30+ containers into a single monolithic <code>docker-compose.yml</code> file. When one database fails or one container has a port conflict, the entire system breaks.
    </p>
    <p>
      By separating each domain (<code>media-server</code>, <code>arr-stack</code>, <code>music-server</code>, <code>book-reader</code>, <code>photo-backup</code>, <code>cloud-storage</code>) into its own dedicated directory inside <code>stacks/</code>, you gain:
    </p>
    <ul>
      <li><strong>Independent Upgrades:</strong> Update Navidrome or Kavita without taking Jellyfin offline.</li>
      <li><strong>Resource Isolation:</strong> Run lightweight services on a Raspberry Pi or N100 mini-PC and heavy AI workloads (Immich) on a dedicated server.</li>
      <li><strong>Zero Overwhelm:</strong> Learn and troubleshoot one service at a time before combining them inside <code>full-stack</code>.</li>
    </ul>

    <!-- Quick health check reference -->
    <h3 class="pt-6">Port Reference & Quick Health Table</h3>
    <HealthTable />
  </div>
</PageLayout>
