---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalAnimation from '../components/TerminalAnimation';
import ServiceCard from '../components/ServiceCard.astro';
import HealthTable from '../components/HealthTable.astro';
import { services } from '../data/services';
---

<BaseLayout
  title="Home"
  description="Take back control of your digital life with self-hosted media, photo backups, and private cloud storage."
>
  <!-- Hero Section -->
  <section class="relative pt-12 pb-20 md:pt-20 md:pb-32 overflow-hidden border-b border-border">
    <div class="absolute inset-0 bg-gradient-radial from-accent/10 via-transparent to-transparent opacity-60 pointer-events-none"></div>
    
    <div class="max-w-6xl mx-auto px-4 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 border border-accent/30 text-accent text-xs font-mono mb-6 animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        <span>Architecture First, Then Implement &bull; 100% Modular &bull; Open Source</span>
      </div>

      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-text max-w-4xl mx-auto leading-tight animate-fade-up">
        Own Your Cloud. <br />
        <span class="gradient-text">Ditch the Subscriptions.</span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed animate-fade-up" style="animation-delay: 0.1s;">
        Why pay $50+ a month for Netflix, Spotify, Kindle Cloud, Google Photos, and Dropbox when you can host them locally on your own hardware with superior privacy and zero ongoing fees?
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4 animate-fade-up" style="animation-delay: 0.2s;">
        <a href="/Homelabbing/getting-started" class="btn-primary text-base shadow-[0_0_30px_rgba(99,102,241,0.3)]">
          Explore Getting Started Guide 🚀
        </a>
        <a href="/Homelabbing/concepts" class="btn-secondary text-base">
          Read Architecture & Concepts →
        </a>
      </div>

      <!-- Terminal Animation Island -->
      <div class="mt-14 animate-fade-up" style="animation-delay: 0.3s;">
        <TerminalAnimation client:load />
      </div>
    </div>
  </section>

  <!-- Core Concepts Banner -->
  <section class="py-16 bg-bg-surface/60 border-b border-border">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="max-w-2xl">
          <span class="text-xs font-mono uppercase tracking-widest text-accent font-semibold">Architecture First Foundation</span>
          <h2 class="text-3xl font-bold text-text mt-2">Understand the Architecture Before Implementing</h2>
          <p class="text-text-muted text-sm md:text-base mt-2 leading-relaxed">
            We believe in learning on your own terms: first understand the architecture, then implement. Explore our 8 step-by-step conceptual guides breaking down ports, container volumes (`/config` vs `/data`), networking, smart home automation, and ad blocking.
          </p>
        </div>
        <a href="/Homelabbing/concepts" class="btn-primary shrink-0">
          Browse All 8 Guides →
        </a>
      </div>
    </div>
  </section>

  <!-- Modular Services Section -->
  <section class="py-20 max-w-6xl mx-auto px-4">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
      <div>
        <span class="text-xs font-mono uppercase tracking-widest text-accent font-semibold">Modular Stacks</span>
        <h2 class="text-3xl md:text-4xl font-bold text-text mt-2">Pick Where You Want to Start</h2>
        <p class="text-text-muted text-sm md:text-base mt-2 max-w-2xl">
          Each application lives in its own dedicated, heavily commented folder inside `stacks/`. Start with Jellyfin or Kavita, then add music, automated downloads, or photo backups when you're ready!
        </p>
      </div>
      <a href="/Homelabbing/services" class="text-accent hover:underline font-semibold text-sm flex items-center gap-1 shrink-0">
        View All Stacks & Filter →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <ServiceCard service={service} />
      ))}
    </div>
  </section>

  <!-- Health & Port Reference -->
  <section class="py-16 bg-bg-surface/50 border-t border-b border-border">
    <div class="max-w-6xl mx-auto px-4">
      <div class="max-w-3xl mb-8">
        <span class="text-xs font-mono uppercase tracking-widest text-accent font-semibold">Live Monitoring</span>
        <h2 class="text-3xl font-bold text-text mt-2">Check All Your Ports in One Command</h2>
        <p class="text-text-muted text-sm mt-2">
          Our diagnostic checker queries container states across all homelab service endpoints (`http://YOUR_SERVER_IP:PORT`) and reports container health directly in your terminal.
        </p>
      </div>

      <HealthTable />
    </div>
  </section>

  <!-- Why Self-Host Banner -->
  <section class="py-20 max-w-6xl mx-auto px-4 text-center">
    <div class="glass p-10 md:p-16 border border-border relative overflow-hidden">
      <div class="absolute -right-20 -bottom-20 w-80 h-80 rounded-full bg-accent/10 blur-3xl pointer-events-none"></div>
      
      <h2 class="text-3xl md:text-4xl font-bold text-text max-w-2xl mx-auto">
        Ready to Build Your Private Home Cloud?
      </h2>
      <p class="text-text-muted max-w-xl mx-auto mt-4 text-base leading-relaxed">
        Join thousands of privacy enthusiasts taking back their data. All Docker Compose blueprints, environment templates, and concept guides are 100% free and open source. Looking for more self-hosted community services and products? Check out the <a href="https://www.awesome-homelab.com/" target="_blank" class="text-accent hover:underline">Awesome-Homelab</a> directory!
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/Homelabbing/getting-started" class="btn-primary">
          Get Started in 5 Minutes →
        </a>
        <a
          href="https://github.com/Zamiul-rashid/Homelabbing"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Star on GitHub ⭐
        </a>
        <a
          href="https://www.awesome-homelab.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Explore Awesome-Homelab 🌐
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
