# ============================================================
#  .env.example — Safe public template. NO REAL VALUES HERE.
#  Instructions: cp .env.example .env  then fill from your vault.
# ============================================================

# --- System / Docker UID/GID ---
PUID=1000
PGID=1000

# --- Timezone ---
TZ=UTC

# --- Networking & Domain ---
# Your server's LAN IP address (e.g. 192.168.1.100)
SERVER_IP=
# Optional full domain for Homepage dashboard if exposed outside LAN (e.g. home.yourdomain.com)
HOMEPAGE_DOMAIN=

# --- Homelab Repo Location ---
# Absolute path to this repo on disk (used by media-stack to mount recyclarr config)
HOMELAB_DIR=/home/YOUR_USERNAME/homelab

# --- Domain / DuckDNS ---
# Your DuckDNS subdomain (just the subdomain part, e.g. your-subdomain)
DUCKDNS_SUBDOMAIN=
# Your DuckDNS token (from duckdns.org/domains)
DUCKDNS_TOKEN=

# --- Nginx Proxy Manager ---
# Email used for Let's Encrypt & NPM admin login
NPM_ADMIN_EMAIL=you@example.com
# Password for the NPM web UI
NPM_ADMIN_PASSWORD=
# Same email used for Let's Encrypt (usually same as NPM_ADMIN_EMAIL)
LE_EMAIL=you@example.com

# --- Nextcloud / MariaDB ---
DB_ROOT_PASSWORD=
DB_PASSWORD=

# --- Paperless-ngx ---
PAPERLESS_ADMIN_USER=
PAPERLESS_ADMIN_PASSWORD=
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
PAPERLESS_SECRET_KEY=
# Full public URL for Paperless (e.g. https://paperless.your-subdomain.duckdns.org)
PAPERLESS_URL=
PAPERLESS_CSRF_TRUSTED_ORIGINS=

# --- *Arr Stack API Keys ---
# These are auto-generated on first run; extract them after first boot:
#   grep -oP '(?<=<ApiKey>)[^<]+' ~/homelab/media-stack/config/radarr/config.xml
RADARR_API_KEY=
SONARR_API_KEY=
PROWLARR_API_KEY=

# --- AudioMuse / Navidrome ---
# Navidrome admin credentials
NAVIDROME_ADMIN_USER=
NAVIDROME_ADMIN_PASSWORD=

# --- AudioMuse DB (PostgreSQL) ---
# Customize if desired
AUDIOMUSE_DB_USER=audiomuse
AUDIOMUSE_DB_PASSWORD=
AUDIOMUSE_DB_NAME=audiomusedb

# --- AudioMuse AI & Worker Options ---
# Options: gemini, openai
AI_MODEL_PROVIDER=gemini
# Gemini API Key (get from Google AI Studio)
GEMINI_API_KEY=
# Or: gemini-1.5-pro, gemini-2.0-flash
GEMINI_MODEL_NAME=gemini-1.5-flash

# --- qBittorrent ---
# Set this after first login (default is a random temp password shown in docker logs)
QB_PASSWORD=

# --- Tailscale ---
# Get from https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=

# --- Backup Encryption ---
# Used by 02-restore.sh to decrypt the NPM/Nextcloud backup archive
BACKUP_ENCRYPTION_PASSWORD=
# Where your encrypted backup archive lives (local path, s3://, or https:// WebDAV)
BACKUP_ARCHIVE_URL=

# --- Backup Upload (WebDAV / Nextcloud) ---
# Only needed if BACKUP_ARCHIVE_URL is an https:// WebDAV endpoint
NC_BACKUP_USER=
NC_BACKUP_PASSWORD=
